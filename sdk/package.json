{
  "name": "@ghos/sdk",
  "version": "0.4.1",
  "description": "TypeScript SDK for the ghos Solana privacy OS. Token-2022 Confidential Balances, twisted ElGamal, bulletproof range proofs, CoinJoin mixing, burner accounts.",
  "keywords": [
    "solana",
    "token-2022",
    "confidential-transfer",
    "privacy",
    "elgamal",
    "bulletproof",
    "zk",
    "coinjoin",
    "ristretto255"
  ],
  "license": "MIT",
  "author": {
    "name": "ghos.xyz core",
    "url": "https://ghos.xyz"
  },
  "homepage": "https://ghos.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghosxyz/ghos.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/ghosxyz/ghos/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
