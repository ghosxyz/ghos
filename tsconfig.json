{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "types": ["mocha", "chai", "node"],
    "paths": {
      "@ghos/sdk": ["./sdk/src"],
      "@ghos/sdk/*": ["./sdk/src/*"]
    }
  },
  "include": ["tests/**/*", "sdk/src/**/*", "examples/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "target", ".anchor", "sdk/dist"]
}
